# ============================================================
#  Copy this file to ".env" and fill in the values.
#  (The app reads .env automatically on startup.)
# ============================================================

# ---- Google service account -------------------------------
# Path to the service-account JSON key you downloaded from Google Cloud.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# The two Google Spreadsheets you created and SHARED (Editor) with the
# service-account email. Paste the ID from each sheet's URL:
# https://docs.google.com/spreadsheets/d/<THIS_IS_THE_ID>/edit
RED_SPREADSHEET_ID=
YELLOW_SPREADSHEET_ID=

# ---- Lanes -------------------------------------------------
# Comma-separated. These become the dropdown options AND the tab names in
# both spreadsheets. Rename them to your real lane names if you like.
LANES=Lane 1,Lane 2,Lane 3,Lane 4,Lane 5,Lane 6,Lane 7,Lane 8,Lane 9,Lane 10

# ---- Source sheet / colour rules ---------------------------
SHEET_NAME=SHIPPING QUEUE
RED_STATUS=OVERDUE
YELLOW_STATUS=TODAY
# replace = overwrite the lane tab each upload | append = keep old rows
RED_MODE=replace
YELLOW_MODE=replace

# ---- Email (Gmail SMTP + App Password) ---------------------
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# The Gmail address that sends the report:
SMTP_SENDER=youraccount@gmail.com
# 16-character Google App Password (NOT your normal password). See README.
SMTP_APP_PASSWORD=
# Who receives the count email (comma-separated):
EMAIL_RECIPIENTS=person1@example.com,person2@example.com

# ---- Flask -------------------------------------------------
FLASK_SECRET=please-change-this-to-a-random-string
MAX_CONTENT_MB=50

# ---- Auth + roles ------------------------------------------
# true  = require login (roles: ops = upload only, admin = dashboard + everything)
# false = dev mode, no login (every request is treated as a built-in admin)
AUTH_ENABLED=true
USERS_FILE=users.json     # hashed logins; seed with:  python manage_users.py add <user> <role>
STATE_FILE=state.json     # local per-lane dashboard record (auto-created)
